  <data key="d0">agent_role</data>
  <data key="d1">RepoStewardAgent</data>
  <data key="d2">Meta-governance owner for repo boundaries, small changes, no auto-merge/auto-run, dependency restraint, and ontology integrity.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:QMLResearcherAgent">
  <data key="d0">agent_role</data>
  <data key="d1">QMLResearcherAgent</data>
  <data key="d2">Researches QML concepts, papers, official docs and frameworks with uncertainty and implementation relevance.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:QMLArchitectAgent">
  <data key="d0">agent_role</data>
  <data key="d1">QMLArchitectAgent</data>
  <data key="d2">Designs QML experiment architecture, feature maps, ansatz choices, backend choices and extension points.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:ClassicalBaselineEngineer">
  <data key="d0">agent_role</data>
  <data key="d1">ClassicalBaselineEngineer</data>
  <data key="d2">Creates baseline-first ML comparisons and protects against QML hype by requiring strong classical baselines.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:ExperimentEngineer">
  <data key="d0">agent_role</data>
  <data key="d1">ExperimentEngineer</data>
  <data key="d2">Implements runnable scripts, small examples, graceful import errors and minimal dependency code changes.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:EvaluatorAgent">
  <data key="d0">agent_role</data>
  <data key="d1">EvaluatorAgent</data>
  <data key="d2">Compares models under controlled conditions and checks leakage, metrics, splits and reproducibility.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:EthicsClaimsReviewer">
  <data key="d0">agent_role</data>
  <data key="d1">EthicsClaimsReviewer</data>
  <data key="d2">Prevents unsupported quantum advantage claims, enforces limitations and aligns language to evidence.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:DocumentationAgent">
  <data key="d0">agent_role</data>
  <data key="d1">DocumentationAgent</data>
  <data key="d2">Maintains README, docs, model/dataset cards, comparison reports and agent-facing explanations.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:ContributionReviewerAgent">
  <data key="d0">agent_role</data>
  <data key="d1">ContributionReviewerAgent</data>
  <data key="d2">Scores contributions using rubric, reviews packets, updates reputation guidance and contribution log.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:TaskBoardCuratorAgent">
  <data key="d0">agent_role</data>
  <data key="d1">TaskBoardCuratorAgent</data>
  <data key="d2">Maintains task board, next-agent instructions, task protocols and safe task proposal workflow.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:SchemaGuardianAgent">
  <data key="d0">agent_role</data>
  <data key="d1">SchemaGuardianAgent</data>
  <data key="d2">Maintains schemas, validation script, benchmark result fixtures and machine-readable contract integrity.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:MCPInterfaceAgent">
  <data key="d0">agent_role</data>
  <data key="d1">MCPInterfaceAgent</data>
  <data key="d2">Maintains local command interface without enabling expensive or uncontrolled automation.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="agent:SecuritySafetyAgent">
  <data key="d0">agent_role</data>
  <data key="d1">SecuritySafetyAgent</data>
  <data key="d2">Reviews secrets, automation boundaries, external calls, dependency additions and uncontrolled agent loops.</data>
  <data key="d6">medium</data>
  <data key="d7">false</data>
</node>
<node id="principle:Principle_ClassicalBaselineRequired">
  <data key="d0">principle</data>
  <data key="d1">ClassicalBaselineRequired</data>
  <data key="d2">Every QML experiment must include a classical baseline.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="principle:Principle_LimitationsRequired">
  <data key="d0">principle</data>
  <data key="d1">LimitationsRequired</data>
  <data key="d2">Every result must include limitations.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="principle:Principle_ClaimsMatchEvidence">
  <data key="d0">principle</data>
  <data key="d1">ClaimsMatchEvidence</data>
  <data key="d2">Every claim must match the evidence; weaken any claim stronger than the data.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="principle:Principle_MetadataRequired">
  <data key="d0">principle</data>
  <data key="d1">MetadataRequired</data>
  <data key="d2">Every experiment records dataset, model, backend, seed, metrics and environment.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="principle:Principle_QMLMetadataRequired">
  <data key="d0">principle</data>
  <data key="d1">QMLMetadataRequired</data>
  <data key="d2">Every QML model reports qubits, circuit depth if available, shots if applicable, and backend/simulator.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="principle:Principle_SmallReadableExamples">
  <data key="d0">principle</data>
  <data key="d1">SmallReadableExamples</data>
  <data key="d2">Prefer small readable examples over complex abstractions.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="principle:Principle_MinimalDependencies">
  <data key="d0">principle</data>
  <data key="d1">MinimalDependencies</data>
  <data key="d2">Do not add large dependencies without explicit justification.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="principle:Principle_TargetedChanges">
  <data key="d0">principle</data>
  <data key="d1">TargetedChanges</data>
  <data key="d2">Do not rewrite the whole repo when a targeted change is sufficient.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="principle:Principle_NoUncontrolledAutomation">
  <data key="d0">principle</data>
  <data key="d1">NoUncontrolledAutomation</data>
  <data key="d2">Do not enable automatic benchmark execution, auto-merge, or uncontrolled agent loops without explicit human approval.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="workflow:Workflow_NewContributor">
  <data key="d0">workflow</data>
  <data key="d1">NewContributor</data>
  <data key="d2">Contributor arrives -&gt; reads instructions -&gt; chooses task -&gt; creates packet -&gt; validates -&gt; PR -&gt; review -&gt; contribution log.</data>
  <data key="d6">medium</data>
  <data key="d7">true</data>
</node>
<node id="workflow:Workflow_DefaultExperiment">
  <data key="d0">workflow</data>
  <data key="d1">DefaultExperiment</data>
  <data key="d2">Plan -&gt; dataset card -&gt; classical baseline -&gt; QML candidate -&gt; manual evaluation -&gt; comparison report -&gt; model card -&gt; ethics review -&gt; next steps.</data>
  <data key="d6">medium</data>
  <data key="d7">true</data>
</node>
<node id="workflow:Workflow_Validation">
  <data key="d0">workflow</data>
  <data key="d1">Validation</data>
  <data key="d2">Run benchmarks/runner.py, mcp/server.py get_results, and scripts/validate_repo.py as appropriate.</data>
  <data key="d6">medium</data>
  <data key="d7">true</data>
</node>
<node id="workflow:Workflow_Review">
  <data key="d0">workflow</data>
  <data key="d1">Review</data>
  <data key="d2">Review contribution packet, baseline integrity, claim status, validation commands, limitations and rubric score.</data>
  <data key="d6">medium</data>
  <data key="d7">true</data>
</node>
<node id="risk:Risk_UnsupportedQuantumAdvantageClaims">
  <data key="d0">risk</data>
  <data key="d1">UnsupportedQuantumAdvantageClaims</data>
  <data key="d6">high</data>
  <data key="d2">Claims exceed evidence, especially from small datasets or toy fixtures.</data>
  <data key="d7">true</data>
</node>
<node id="risk:Risk_MissingClassicalBaseline">
  <data key="d0">risk</data>
  <data key="d1">MissingClassicalBaseline</data>
  <data key="d6">high</data>
  <data key="d2">QML result lacks comparable classical baseline.</data>
  <data key="d7">true</data>
</node>
<node id="risk:Risk_BenchmarkGaming">
  <data key="d0">risk</data>
  <data key="d1">BenchmarkGaming</data>
  <data key="d6">high</data>
  <data key="d2">Optimizing reported score without preserving scientific value or reproducibility.</data>
  <data key="d7">true</data>
</node>
<node id="risk:Risk_DependencySprawl">
  <data key="d0">risk</data>
  <data key="d1">DependencySprawl</data>
  <data key="d6">medium</data>
  <data key="d2">Adding heavy frameworks or build systems without clear justification.</data>
  <data key="d7">true</data>
</node>
<node id="risk:Risk_UncontrolledAgentLoops">
  <data key="d0">risk</data>
  <data key="d1">UncontrolledAgentLoops</data>
  <data key="d6">high</data>
  <data key="d2">Agents auto-generate, auto-run, auto-merge or mutate board/state without approval.</data>
  <data key="d7">true</data>
</node>
<node id="risk:Risk_LargeUnreviewedRewrite">
  <data key="d0">risk</data>
  <data key="d1">LargeUnreviewedRewrite</data>
  <data key="d6">high</data>
  <data key="d2">Broad rewrite reduces auditability and maintainability.</data>
  <data key="d7">true</data>
</node>
<node id="gate:Gate_BaselineIntegrity">
  <data key="d0">review_gate</data>
  <data key="d1">BaselineIntegrity</data>
  <data key="d2">Classical baseline present, comparable and strong enough for claim context.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="gate:Gate_Reproducibility">
  <data key="d0">review_gate</data>
  <data key="d1">Reproducibility</data>
  <data key="d2">Dataset, split, seed, metrics, backend and environment recorded.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="gate:Gate_ClaimDiscipline">
  <data key="d0">review_gate</data>
  <data key="d1">ClaimDiscipline</data>
  <data key="d2">Claim status and prose match recorded result and limitations.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="gate:Gate_SmallChange">
  <data key="d0">review_gate</data>
  <data key="d1">SmallChange</data>
  <data key="d2">Change is small, reversible and auditable.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="gate:Gate_Validation">
  <data key="d0">review_gate</data>
  <data key="d1">Validation</data>
  <data key="d2">Benchmark runner/MCP/validate_repo checks run where relevant.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
<node id="gate:Gate_HumanApproval">
  <data key="d0">review_gate</data>
  <data key="d1">HumanApproval</data>
  <data key="d2">Auto-run/auto-merge/uncontrolled loops require explicit human approval.</data>
  <data key="d6">high</data>
  <data key="d7">true</data>
</node>
