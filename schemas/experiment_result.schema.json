{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QML Agent Lab Experiment Result",
  "type": "object",
  "required": [
    "experiment_id",
    "dataset",
    "version",
    "classical_baseline",
    "delta_vs_classical",
    "claim_status",
    "limitations"
  ],
  "properties": {
    "experiment_id": {"type": "string"},
    "dataset": {"type": "string"},
    "version": {"type": "string"},
    "classical_baseline": {"type": "object"},
    "quantum_model": {"type": ["object", "null"]},
    "delta_vs_classical": {"type": ["number", "null"]},
    "claim_status": {"type": "string"},
    "limitations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "notes": {"type": "string"}
  }
}
